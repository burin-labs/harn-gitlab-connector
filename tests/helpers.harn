import {
  activate,
  call,
  init,
  kinds,
  normalize_inbound,
  payload_schema,
  provider_id,
  shutdown,
} from "../src/lib"

pub fn gitlab_headers(token, event, event_uuid = "event-uuid-1") {
  return {"x-gitlab-event": event, "x-gitlab-event-uuid": event_uuid, "x-gitlab-token": token}
}

/**
 * Build a raw inbound envelope WITHOUT embedding the signing secret. Tests must seed the secret via `init({signing_secret: secret})` before calling normalize_inbound.
 */
pub fn signed_raw(token, body, event, extra = nil) {
  return (extra ?? {}) + {body_text: body, headers: gitlab_headers(token, event)}
}

/** Read a fixture JSON body from the test fixtures directory. */
pub fn fixture_body(name) {
  return harness.fs.read_text(source_dir() + "/fixtures/webhooks/" + name + ".json")
}

/** Build a signed raw inbound envelope from a named fixture. */
pub fn fixture_raw(name, token, event, extra = nil) {
  return signed_raw(token, fixture_body(name), event, extra)
}

pub fn assert_gitlab_interface() {
  shutdown()
  assert_eq(provider_id(), "gitlab", "provider id")
  assert_eq(kinds()[0], "webhook", "webhook kind")
  assert_eq(payload_schema().harn_schema_name, "GitLabEventPayload", "payload schema name")
  const initialized = init({signing_secret: "test-secret"})
  assert(initialized.initialized, "init stores state")
  const activated = activate(
    [{id: "primary", path: "/gitlab/events", secrets: {signing_secret: "test-secret"}}],
  )
  assert_eq(activated.bindings, 1, "activate counts bindings")
}

pub fn gitlab_call(method, args) {
  return call(method, args)
}

pub fn gitlab_normalize(raw) {
  return normalize_inbound(raw)
}
